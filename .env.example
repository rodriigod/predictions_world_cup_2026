# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=ml_project

# API Keys
API_KEY=your_api_key_here
SECRET_KEY=your_secret_key_here

# --- Odds en vivo (scripts/fetch_odds_2026.py) ---
ODDS_API_KEY=your_the_odds_api_key   # https://the-odds-api.com (free tier)

# --- Dossier por partido (scripts/match_dossier.py) ---
# Gemini es OPCIONAL: por defecto el dossier usa DuckDuckGo (--search ddg, sin key).
GEMINI_API_KEY=your_gemini_key       # solo si usás --search gemini
GEMINI_MODEL=gemini-flash-latest
# LM Studio local (Qwen): server OpenAI-compatible. NO necesita API key por defecto.
LMSTUDIO_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=qwen2.5-7b-instruct   # = "API Model Identifier" en LM Studio
LMSTUDIO_API_KEY=                    # dejar vacío salvo que actives auth en LM Studio

# Paths
DATA_PATH=./files/f0_raw
OUTPUT_PATH=./files/f3_output
MODELS_PATH=./models

# Model Configuration
RANDOM_SEED=42
TEST_SIZE=0.2
VALIDATION_SIZE=0.1

# Training Parameters
BATCH_SIZE=32
EPOCHS=100
LEARNING_RATE=0.001

# Logging
LOG_LEVEL=INFO
DEBUG=False
